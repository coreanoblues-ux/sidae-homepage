{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "npm run build",
    "nixpacksPlan": {
      "variables": {
        "NIXPACKS_NODE_VERSION": "20"
      }
    }
  },
  "deploy": {
    "startCommand": "npm run start",
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 5
  }
}
