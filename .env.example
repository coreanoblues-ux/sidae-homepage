# Node Environment
NODE_ENV=production
PORT=3000

# Database
DATABASE_URL=postgresql://user:password@host:port/database

# API Configuration
API_ORIGIN=https://your-railway-domain.up.railway.app
FRONT_ORIGIN=https://your-railway-domain.up.railway.app
COOKIE_DOMAIN=your-domain.com

# Authentication
SESSION_SECRET=your-secure-random-string-here
JWT_SECRET=your-jwt-secret-here
SUPERADMIN_PASSWORD=your-superadmin-password

# OpenID Connect (선택사항)
ISSUER_URL=https://your-auth-provider.com

# Note: REPLIT_DOMAINS, REPL_ID는 Railway에서 필요 없습니다
